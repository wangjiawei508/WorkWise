# Copy to scripts/release.local.env.
# This file is intentionally safe to commit; release.local.env is ignored.

### WorkWise official download mirror / Cloudflare R2 / S3 upload
S3_BUCKET=workwise
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<r2-access-key-id>
S3_SECRET_ACCESS_KEY=<r2-secret-access-key>

# Product page shown to users when they click manual download/update links.
WORKWISE_DOWNLOAD_URL=https://www.railwise.cn/products/workwise/

# Public static-file domain used in electron-updater metadata.
# This must point to the directory where latest.yml/latest-mac.yml and installers are uploaded.
# The current company website serves this path through OnePanel/OpenResty:
#   https://www.railwise.cn/downloads/workwise/
WORKWISE_PUBLIC_BASE_URL=https://www.railwise.cn/downloads
WORKWISE_RELEASE_PREFIX=workwise

# Legacy names remain supported if your CI already uses them.
# R2_PUBLIC_BASE_URL=https://www.railwise.cn/downloads
# R2_RELEASE_PREFIX=workwise

# Default release channel for scripts when --channel is not passed.
# The project default is frontier; pass --stable or --channel stable for stable releases.
RELEASE_CHANNEL=frontier

### macOS signing and notarization
P12_PATH=/path/to/develop-id.p12
P12_PASSWORD=<p12-password>
P8_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
KEY_ID=<apple-key-id>
ISSUER=<apple-issuer-uuid>
