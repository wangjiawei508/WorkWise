{
  "name": "workwise",
  "productName": "WorkWise",
  "version": "0.2.3",
  "description": "AI workbench for engineering, infrastructure, and operations workflows",
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:kun && electron-vite dev",
    "build": "npm run build:kun && electron-vite build",
    "build:kun": "node ./scripts/ensure-kun-install.cjs && npm --prefix kun run build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && npx --yes electron-builder@26.8.1 --config electron-builder.cjs --publish never",
    "dist:mac": "rm -f dist/WorkWise-*-mac-* dist/latest-mac.yml && npm run build && npm run dist:mac:x64:dmg && npm run dist:mac:arm64:dmg",
    "dist:mac:signed": "rm -f dist/WorkWise-*-mac-* dist/latest-mac.yml && npm run build && MAC_SIGN=1 npm run dist:mac:x64:dmg && MAC_SIGN=1 npm run dist:mac:arm64:dmg",
    "dist:mac:arm64": "npm run build && npm run dist:mac:arm64:dmg",
    "dist:mac:x64": "npm run build && npm run dist:mac:x64:dmg",
    "dist:mac:arm64:dmg": "npx --yes electron-builder@26.8.1 --config electron-builder.cjs --publish never --mac dmg --arm64",
    "dist:mac:x64:dmg": "npx --yes electron-builder@26.8.1 --config electron-builder.cjs --publish never --mac dmg --x64",
    "dist:win": "npm run dist -- --win nsis --x64",
    "release:all": "bash ./scripts/release-mac.sh",
    "release:mac": "bash ./scripts/release-mac.sh",
    "release:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-win.ps1",
    "prepare:converters": "node ./scripts/prepare-markdown-converters.cjs",
    "r2:upload": "node ./scripts/publish-r2.mjs upload",
    "r2:promote": "node ./scripts/publish-r2.mjs promote",
    "postinstall": "node ./scripts/postinstall.cjs",
    "verify:apple": "node ./scripts/verify-apple-signing.cjs",
    "verify:release-assets": "node ./scripts/verify-release-assets.cjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "mac:unquarantine": "bash ./scripts/mac-unquarantine.sh",
    "generate:icons": "electron ./scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tencent-weixin/openclaw-weixin": "2.4.3",
    "better-sqlite3": "^12.10.0",
    "docx": "^9.7.1",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "html-to-docx": "^1.8.0",
    "i18next": "^25.4.2",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.544.0",
    "markdown-it": "^14.2.0",
    "openclaw": "file:vendor/openclaw-shim",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.7.4",
    "react-markdown": "^10.1.0",
    "rehype-harden": "^1.1.8",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/html-to-docx": "^1.8.1",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "^34.2.0",
    "electron-vite": "^3.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.2.0",
    "vitest": "^4.1.7"
  },
  "author": "WorkWise Contributors",
  "homepage": "https://github.com/wangjiawei508/WorkWise",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangjiawei508/WorkWise.git"
  }
}
